#nexus

BEGIN Taxa;
DIMENSIONS ntax=5;
TAXLABELS
[1] 'Bg'
[2] 'Bb'
[3] 'Pk'
[4] 'Ip'
[5] 'Ee'
;
END; [Taxa]

BEGIN Splits;
DIMENSIONS ntax=5 nsplits=9;
FORMAT labels=no weights=yes confidences=no intervals=no;
MATRIX
	100	 2,
	100	 3,
	100	 2 3,
	100	 4,
	100	 5,
	13	 4 5,
	100	 1,
	63	 1 5,
	24	 1 4,
;
END; [Splits]

